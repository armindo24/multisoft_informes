#!/usr/bin/env node

/**
 * Module dependencies.
 */

var config;
try {
    config = require('config');
} catch (e) {
    console.warn('config module not found, using fallback config. Install "config" for full functionality.');
    config = { get: function () { return {}; } };
}
var shell = require('shelljs');
var app = require('../app');
var debug = require('debug')('multisoft:server');
var http = require('http');
var dbIntegrado = require('../db_integrado');
var dbSueldo = require('../db_sueldo');

function isSchemaError(err) {
    var code = err && (err.code || err.Code);
    return code === -141 || code === -143 || code === -149;
}

function formatSchemaMessage(err) {
    var msg = String((err && (err.message || err.Msg || err.sqlMessage)) || err || '');
    var code = (err && (err.code || err.Code));
    if (isSchemaError(err)) {
        return '[DB-SCHEMA] Error de estructura (tabla/columna). Code=' + code + ' Msg=' + msg;
    }
    return '[UNCAUGHT] ' + msg;
}

/**
 * Get port from environment and store in Express.
 */
//console.log(process.env)
var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

process.on('SIGINT', function () {
    console.log("\nGracefully shutting down from SIGINT (Ctrl-C)");
    dbIntegrado.discon();
    dbSueldo.discon();
    process.exit(0);
});

// Nodedemon restart
process.once('SIGUSR2', function () {
    console.log("\nGracefully restarting.");
    dbIntegrado.discon();
    dbSueldo.discon();
    process.kill(process.pid, 'SIGUSR2');
});

// Evita caída del proceso por errores async no manejados (p.ej. tabla/columna inexistente en SQL).
process.on('uncaughtException', function (err) {
    console.error(formatSchemaMessage(err));
    if (err && err.stack) {
        console.error(err.stack);
    }
    // No hacemos process.exit para mantener el servicio disponible.
});

process.on('unhandledRejection', function (reason) {
    console.error('[UNHANDLED_REJECTION]', reason && (reason.stack || reason.message) ? (reason.stack || reason.message) : reason);
    // No hacemos process.exit para mantener el servicio disponible.
});

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

// El informe de costo_articulo_full puede tardar varios minutos cuando
// recalcula materiales + despachos; evitamos que Node cierre la conexion
// HTTP a los ~120s antes de que termine el procesamiento.
server.requestTimeout = 10 * 60 * 1000;
server.headersTimeout = 11 * 60 * 1000;
server.keepAliveTimeout = 65 * 1000;

/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
    var port = parseInt(val, 10);

    if (isNaN(port)) {
        // named pipe
        return val;
    }

    if (port >= 0) {
        // port number
        return port;
    }

    return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
    if (error.syscall !== 'listen') {
        throw error;
    }

    var bind = typeof port === 'string'
        ? 'Pipe ' + port
        : 'Port ' + port;

    // handle specific listen errors with friendly messages
    switch (error.code) {
        case 'EACCES':
            console.error(bind + ' requires elevated privileges');
            process.exit(1);
            break;
        case 'EADDRINUSE':
            console.error(bind + ' is already in use');
            process.exit(1);
            break;
        default:
            throw error;
    }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
    var addr = server.address();
    var bind = typeof addr === 'string'
        ? 'pipe ' + addr
        : 'port ' + addr.port;
    debug('Listening on ' + bind);
}
