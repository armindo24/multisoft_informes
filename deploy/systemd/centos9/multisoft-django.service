[Unit]
Description=Multisoft Django (CentOS 9)
After=network.target

[Service]
Type=simple
User=multisoft
Group=multisoft
WorkingDirectory=/opt/multisoft/multisoft_informes
Environment=DJANGO_SETTINGS_MODULE=multisoft_informes.settings.production
ExecStart=/opt/multisoft/multisoft_informes/.venv/bin/gunicorn multisoft_informes.wsgi:application --bind 127.0.0.1:8000 --workers 3 --timeout 120
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
