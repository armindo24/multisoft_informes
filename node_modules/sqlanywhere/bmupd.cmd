pushd %dbdir%\dbnodejs\sqlanywhere

call updmkdir Node sqlanywhere
call updmkdir Node sqlanywhere src
call updmkdir Node sqlanywhere src h
call updmkdir Node sqlanywhere bin32
call updmkdir Node sqlanywhere bin64
call updmkdir Node sqlanywhere lib

call updcopy package.json	    Node\sqlanywhere
call updcopy binding.gyp	    Node\sqlanywhere
call updcopy build.js		    Node\sqlanywhere
call updcopy README.md		    Node\sqlanywhere
call updcopy lib\index.js	    Node\sqlanywhere\lib

call updcopy src\sacapidll.cpp	    Node\sqlanywhere\src
call updcopy src\sqlanywhere.cpp    Node\sqlanywhere\src
call updcopy src\utils.cpp	    Node\sqlanywhere\src
call updcopy src\sqlanywhere_v0_10.cpp Node\sqlanywhere\src
call updcopy src\utils_v0_10.cpp    Node\sqlanywhere\src
call updcopy src\h\connection.h	    Node\sqlanywhere\src\h
call updcopy src\h\errors.h	    Node\sqlanywhere\src\h
call updcopy src\h\sacapi.h	    Node\sqlanywhere\src\h
call updcopy src\h\sacapidll.h	    Node\sqlanywhere\src\h
call updcopy src\h\stmt.h	    Node\sqlanywhere\src\h
call updcopy src\h\sqlany_utils.h   Node\sqlanywhere\src\h

@call bldtarg %1
@goto %bldtarg%

:first

:nt
setlocal
set srcobj=%objdir%\nt_ms_x86_vs12_p

call updcopy %srcobj%\sqlanywhere_v0_10.node  Node\sqlanywhere\bin32
call updcopy %srcobj%\sqlanywhere_v0_12.node  Node\sqlanywhere\bin32
call updcopy %srcobj%\sqlanywhere_v4.node  Node\sqlanywhere\bin32
call updcopy %srcobj%\sqlanywhere_v5.node  Node\sqlanywhere\bin32
endlocal
@if not [%1] == [] goto done

:x64
setlocal
set srcobj=%objdir%\nt_ms_amd64_vs12_p

call updcopy %srcobj%\sqlanywhere_v0_10.node  Node\sqlanywhere\bin64
call updcopy %srcobj%\sqlanywhere_v0_12.node  Node\sqlanywhere\bin64
call updcopy %srcobj%\sqlanywhere_v4.node  Node\sqlanywhere\bin64
call updcopy %srcobj%\sqlanywhere_v5.node  Node\sqlanywhere\bin64

@if not [%1] == [] goto done

rem build package
@echo on
pushd %reldir%\Node\sqlanywhere
call rm -f sqlanywhere-*.tgz
call npm pack
call updcopy sqlanywhere-*.tgz Node
popd
@echo off

:done
popd
