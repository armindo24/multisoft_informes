#
# To get the JavaScript Driver to compile, the NODEGYP_ROOT_DIR needs to be
# environment variable needs to be added pointing to the root directory of 
# Node-Gyp which contains the required header and .lib files. 
# A copy of Node-Gyp as well as the Node.js executables have been checked into 
# the tools/nodejs directory.
#
# Also, to use the drivers, the root folder containing the driver binaries must 
# be visible in the NODE_PATH system variable for Node.js to locate the driver.
# The drivers have been checked into the tools/nodejs/NODE_PATH folder, so 
# we can just create a system variable NODE_PATH pointing to that directory
#
# Lastly, the node.js executables are also checked into the tools/nodejs
# directory.
#

CURRENT_TARGET_LIST = ;

if $(TARGET_OS) = NT || $(TARGET_OS) = LINUX {

    local ver ;

    if ! $(NODEJS_VERS) {
       NODEJS_VERS = $(NODEGYP_VER) ;
       NODEJS_ROOT_DIR = $(NODEGYP_ROOT_DIR)$(SLASH).. ;

       if $(TARGET_OS) = NT {
       	  if $(TARGET_HW) = X86 {
       	     libdir = ia32 ;
          } else {
       	     libdir = x64 ;
       	  }
	  PackageLib nodelib$(NODEGYP_VER)
		     : NAME          node.lib
		     : LIBDIRS       $(NODEGYP_ROOT_DIR)$(SLASH)$(libdir)
		     : NAME_IS_NOT_UNIQUE
		     : ALLOW_CPP_EXCEPTIONS	
		     ;
       }
    }

    for ver in $(NODEJS_VERS) {
	local large_version, small_version, node_version, node_dir ;

	large_version = [ MATCH ([0-9]+)\.[0-9]+\.[0-9]+ : $(ver) ] ;
	if $(large_version) > 1 {
    	   node_version = _v$(large_version) ;
	} else {
	   small_version = [ MATCH [0-9]+\.([0-9]+)\.[0-9]+ : $(ver) ] ;
    	   node_version = _v$(large_version)_$(small_version) ;
	}
	node_dir = $(NODEJS_ROOT_DIR)$(SLASH)$(ver) ;

	PackageDll sqlanywhere$(node_version)
	    : NAME			sqlanywhere$(node_version).node
	    : THREADS			POSIX
	    : MIN_WIN_VER   		0x0501
	    : RESPECT_NAME_SUFFIX_ON 	$(TARGET_OS)
	    : NO_LIB_PREFIX
	    : NO_TM_SUFFIX
	    : IGNORE_WARNINGS
	    ;

	SQLANYWHERE$(node_version)_FILES = sqlanywhere.cpp utils.cpp sacapidll.cpp 
					   sqlanywhere_v0_10.cpp utils_v0_10.cpp 
					   ;

	if $($(TARGET_OS)_BASE) = UNIX {
	    SQLANYWHERE$(node_version)_CFLAGS = -std=c++0x -DDRIVER_NAME=sqlanywhere$(node_version) ;
	}

	if $(TARGET_OS) = NT {
	    SQLANYWHERE$(node_version)_CFLAGS = /EHsc /DDRIVER_NAME=sqlanywhere$(node_version) ;	
	    JS_OS_PKGS = nodelib$(ver).pkg ;
	}
	NODE_DIRS = $(node_dir)$(SLASH)src ;
	NODE_DIRS += $(node_dir)$(SLASH)deps$(SLASH)v8 ;
	NODE_DIRS += $(node_dir)$(SLASH)deps$(SLASH)v8$(SLASH)include ;
	NODE_DIRS += $(node_dir)$(SLASH)deps$(SLASH)v8$(SLASH)src ;
	NODE_DIRS += $(node_dir)$(SLASH)deps$(SLASH)uv$(SLASH)include ;

	Build sqlanywhere$(node_version)
	      : system.pkg $(JS_OS_PKGS) $(SQLANYWHERE$(node_version)_FILES)
	      : . 
	      : $(NODE_DIRS)
	        .$(SLASH)h
	      ;
    } # ver
} # platforms

Project sqla_node_driver : $(CURRENT_TARGET_LIST) ;
